# Server Port Configuration
PORT=3000

# Database Configuration (Local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/smart-grocery

# Secret for express-session signature
SESSION_SECRET=a_long_random_string_for_signing_cookies

# Application URLs (For CORS and redirects)
BASE_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# Google OAuth Credentials (Obtain from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OpenRouter API Key for Gemma Translation Model
OPENROUTER_API_KEY=your_openrouter_api_key
